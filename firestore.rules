rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function allowedProfileKeys() {
      return [
        "uid",
        "email",
        "fullName",
        "companyType",
        "entrepreneurType",
        "businessSector",
        "onboardingCompleted",
        "createdAt",
        "updatedAt"
      ];
    }

    function isValidProfileWrite(uid) {
      return isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly(allowedProfileKeys());
    }

    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isValidProfileWrite(uid);
      allow delete: if false;

      match /chatSessions/{sessionId} {
        allow read: if isOwner(uid);
        allow write: if false;

        match /messages/{messageId} {
          allow read: if isOwner(uid);
          allow write: if false;
        }
      }

      match /reports/{reportId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }
  }
}
